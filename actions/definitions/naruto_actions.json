{
  "_description": "火影忍者格斗 — 全身姿态动作定义。v1.02-final: 所有阈值重新校准。",
  "version": "1.0.2",
  "player_count": 1,

  "_calibration_notes": {
    "参考": "生物力学文献 + MediaPipe 33关键点坐标系",
    "关键修复": [
      "1. trunk_tilt: 从 40-80(不可能) → 0.06-0.30 (比值, 站立前倾实际值)",
      "2. both_hands_up shoulder: 从 10-50(颠倒) → 140-185(手举过头)",
      "3. vertical_velocity: 修复代码层 Bug, 改用 hip_vertical (y轴) 而非 center_offset (x轴)",
      "4. punch elbow: 从 150°下限 → 168°, 避免放松站立误触发",
      "5. squat knee: 从 50-120 → 45-135, 放宽半蹲兼容"
    ]
  },

